# Mira - Environment Variables
# Copy this to .env and fill in your values

# ===============================
# LLM PROVIDERS
# ===============================

# Required: OpenRouter API key for LLM access
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Primary model for general tasks (default: qwen/qwen-2.5-72b-instruct)
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Model for deep reasoning tasks (default: deepseek/deepseek-chat)
OPENROUTER_MODEL_DEEP=deepseek/deepseek-chat

# Optional: Local Ollama for faster/free inference
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# ===============================
# TELEGRAM (Primary Interface)
# ===============================

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your chat ID from @userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===============================
# SOCIAL MEDIA (Optional)
# ===============================

# Twitter/X API credentials
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# LinkedIn OAuth token
LINKEDIN_ACCESS_TOKEN=

# Typefully API key (for Twitter scheduling)
TYPEFULLY_API_KEY=

# ===============================
# EMAIL (Optional)
# ===============================

# Gmail API credentials path
GMAIL_CREDENTIALS_PATH=.credentials/gmail_credentials.json

# ===============================
# BROWSER AUTOMATION (Optional)
# ===============================

# Playwright browser (chromium, firefox, webkit)
PLAYWRIGHT_BROWSER=chromium

# ===============================
# VOICE/TTS (Optional)
# ===============================

# OpenAI API key for TTS (or use macOS built-in)
OPENAI_API_KEY=
