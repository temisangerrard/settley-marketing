#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules/@tloncorp/tlon-skill/bin/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules/@tloncorp/tlon-skill/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules/@tloncorp/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules/@tloncorp/tlon-skill/bin/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules/@tloncorp/tlon-skill/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules/@tloncorp/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/@tloncorp+tlon-skill@0.2.2/node_modules:/Users/steipete/Projects/clawdbot/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@tloncorp/tlon-skill/bin/tlon.js" "$@"
else
  exec node  "$basedir/../@tloncorp/tlon-skill/bin/tlon.js" "$@"
fi
